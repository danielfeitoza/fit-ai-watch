{
  "configVersion": "v3",
  "app": {
    "appId": 28095,
    "appName": "Fit AI Coach",
    "appType": "app",
    "version": {
      "code": 1,
      "name": "1.0.1"
    },
    "icon": "icon.png",
    "vender": "zepp",
    "description": "Fit AI Coach app"
  },
  "permissions": [
    "data:os.device.info",
    "device:os.local_storage",
    "device:os.alarm",
    "device:os.bg_service",
    "device:os.notification"
  ],
  "runtime": {
    "apiVersion": {
      "compatible": "3.0.0",
      "target": "3.0.0",
      "minVersion": "3.0"
    }
  },
  "debug": false,
  "targets": {
    "gt": {
      "module": {
        "page": {
          "pages": [
            "page/gt/home/index.page"
          ]
        },
        "service": {
          "services": [
            {
              "path": "service/timer_bg"
            }
          ]
        },
        "app-side": {
          "path": "app-side/index"
        }
      },
      "platforms": [
        {
          "st": "r"
        },
        {
          "st": "s"
        }
      ],
      "designWidth": 480
    }
  },
  "i18n": {
    "en-US": {
      "appName": "Fit AI Coach"
    }
  },
  "defaultLanguage": "en-US"
}
